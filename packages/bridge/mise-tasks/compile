#!/usr/bin/env bash
#MISE description="Compile the local bridge for a target platform."
#USAGE flag "--target <target>" help="Target platform: linux-x64, macos-arm64, or windows-x64" {
#USAGE   choices "linux-x64" "macos-arm64" "windows-x64"
#USAGE }
#USAGE flag "--version <version>" default="0.0.0-development" help="Version to embed in the binary."

set -euo pipefail

build_version="${usage_version:-0.0.0-development}"
if [[ ! "${build_version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?(\+[0-9A-Za-z.-]+)?$ ]]; then
  printf 'Invalid build version: %s\n' "${build_version}" >&2
  exit 1
fi
build_version_define="\"${build_version}\""

case "${usage_target}" in
  linux-x64)
    bun_target="bun-linux-x64"
    outfile="../../dist/mikoto-bridge-linux-x64"
    ;;
  macos-arm64)
    bun_target="bun-darwin-arm64"
    outfile="../../dist/mikoto-bridge-macos-arm64"
    ;;
  windows-x64)
    bun_target="bun-windows-x64"
    outfile="../../dist/mikoto-bridge-windows-x64.exe"
    ;;
esac

bun build --compile --target="${bun_target}" \
  --define "MIKOTO_BUILD_VERSION=${build_version_define}" \
  --outfile="${outfile}" \
  src/index.ts
