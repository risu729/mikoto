{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "mikoto-docs",
	"compatibility_date": "2026-07-21",
	"workers_dev": false,
	"preview_urls": true,
	"upload_source_maps": true,
	"routes": [
		{
			"pattern": "mikoto.takuk.me",
			"custom_domain": true,
		},
	],
	"assets": {
		"directory": "./dist",
		"not_found_handling": "404-page",
	},
	"observability": {
		"logs": {
			"enabled": true,
		},
		"traces": {
			"enabled": true,
		},
	},
}
