{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://mikoto.takuk.me/schemas/mikoto.schema.json",
	"title": "Mikoto configuration",
	"description": "Configuration for the Mikoto local bridge and backend MCP servers.",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"bridge": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"id": {
					"type": "string",
					"minLength": 1,
					"pattern": "^[A-Za-z0-9_.-]+$",
					"description": "Optional bridge identity. Defaults to the local computer name when omitted."
				}
			}
		},
		"relay": {
			"type": "object",
			"additionalProperties": false,
			"required": ["url"],
			"properties": {
				"url": {
					"type": "string",
					"minLength": 1,
					"pattern": "^wss?://.+",
					"description": "Relay WebSocket URL."
				}
			}
		},
		"servers": {
			"type": "array",
			"default": [],
			"items": {
				"oneOf": [{ "$ref": "#/$defs/stdioServer" }, { "$ref": "#/$defs/httpServer" }]
			}
		}
	},
	"required": ["relay"],
	"$defs": {
		"serverId": {
			"type": "string",
			"minLength": 1,
			"pattern": "^[A-Za-z0-9_-]+$"
		},
		"toolName": {
			"type": "string",
			"minLength": 1,
			"pattern": "^[A-Za-z0-9_.-]+$"
		},
		"toolAlias": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "target"],
			"properties": {
				"name": {
					"type": "string",
					"minLength": 1
				},
				"target": {
					"$ref": "#/$defs/toolName"
				}
			}
		},
		"aliases": {
			"type": "array",
			"default": [],
			"items": {
				"$ref": "#/$defs/toolAlias"
			}
		},
		"stdioServer": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "transport", "command"],
			"properties": {
				"aliases": {
					"$ref": "#/$defs/aliases"
				},
				"id": {
					"$ref": "#/$defs/serverId"
				},
				"transport": {
					"const": "stdio"
				},
				"command": {
					"type": "string",
					"minLength": 1
				},
				"args": {
					"type": "array",
					"default": [],
					"items": {
						"type": "string"
					}
				},
				"cwd": {
					"type": "string"
				},
				"env": {
					"type": "object",
					"default": {},
					"propertyNames": {
						"type": "string",
						"minLength": 1
					},
					"additionalProperties": {
						"type": "string"
					}
				}
			}
		},
		"httpServer": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "transport", "url"],
			"properties": {
				"aliases": {
					"$ref": "#/$defs/aliases"
				},
				"id": {
					"$ref": "#/$defs/serverId"
				},
				"transport": {
					"const": "http"
				},
				"url": {
					"type": "string",
					"minLength": 1,
					"pattern": "^https?://.+"
				}
			}
		}
	}
}
