#!/usr/bin/env bash
#MISE description="Build and package release archives."
#USAGE flag "--version <version>" help="Release version to embed and package."

set -euo pipefail

release_version="${usage_version:?--version is required}"
release_directory="${PWD}/dist/release"
staging_directory="$(mktemp -d)"
trap 'rm -rf "${staging_directory}"' EXIT

rm -rf "${release_directory}"
mkdir -p \
  "${release_directory}" \
  "${staging_directory}/linux-x64" \
  "${staging_directory}/macos-arm64" \
  "${staging_directory}/windows-x64"

for package in codex-mcp bridge; do
  for target in linux-x64 macos-arm64 windows-x64; do
    mise "//packages/${package}:compile" \
      --target "${target}" \
      --version "${release_version}"
  done
done

install -m 0755 dist/mikoto-bridge-linux-x64 \
  "${staging_directory}/linux-x64/mikoto-bridge"
install -m 0755 dist/mikoto-codex-mcp-linux-x64 \
  "${staging_directory}/linux-x64/mikoto-codex-mcp"
install -m 0755 dist/mikoto-bridge-macos-arm64 \
  "${staging_directory}/macos-arm64/mikoto-bridge"
install -m 0755 dist/mikoto-codex-mcp-macos-arm64 \
  "${staging_directory}/macos-arm64/mikoto-codex-mcp"
install -m 0755 dist/mikoto-bridge-windows-x64.exe \
  "${staging_directory}/windows-x64/mikoto-bridge.exe"
install -m 0755 dist/mikoto-codex-mcp-windows-x64.exe \
  "${staging_directory}/windows-x64/mikoto-codex-mcp.exe"

tar -C "${staging_directory}/linux-x64" \
  -czf "${release_directory}/mikoto-v${release_version}-linux-x64.tar.gz" \
  mikoto-bridge mikoto-codex-mcp
tar -C "${staging_directory}/macos-arm64" \
  -czf "${release_directory}/mikoto-v${release_version}-macos-arm64.tar.gz" \
  mikoto-bridge mikoto-codex-mcp
(
  cd "${staging_directory}/windows-x64"
  zip -q "${release_directory}/mikoto-v${release_version}-windows-x64.zip" \
    mikoto-bridge.exe mikoto-codex-mcp.exe
)

for binary in dist/mikoto-bridge-linux-x64 dist/mikoto-codex-mcp-linux-x64; do
  actual_version="$("${binary}" --version)"
  if [[ "${actual_version}" != "${release_version}" ]]; then
    printf 'Expected release version %s from %s, got %s\n' \
      "${release_version}" "${binary}" "${actual_version}" >&2
    exit 1
  fi
done
